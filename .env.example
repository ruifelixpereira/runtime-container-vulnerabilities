# Azure subscription ID(s), comma-separated for multiple
SUBSCRIPTION_ID=""

# Resource group containing Arc-enabled K8s clusters
RESOURCE_GROUP=""

# Comma-separated Arc cluster names (leave empty to scan all clusters in the resource group)
CLUSTER_NAMES=""

# Comma-separated ACR registry names to filter vulnerability findings (leave empty for all)
REGISTRY_NAMES=""

# Namespaces to exclude from runtime image scanning
NAMESPACES_EXCLUDE="kube-system,kube-public,kube-node-lease,gatekeeper-system,azure-arc"

# Minimum severity to include in the report: Critical, High, Medium, Low
SEVERITY_THRESHOLD="Medium"

# Output format: table, json, csv
OUTPUT_FORMAT="table"
